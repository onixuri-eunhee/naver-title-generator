# Override site URL for OG/metadata in dev and preview deployments
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API Key — Whisper 전사 (Phase F 음성 업로드) + GPT Image 레거시 fallback
OPENAI_API_KEY=sk-...

# ── 내부 비서팀 API 키 (2026-04-30 도입) ──
# 무제한 호출 + rate limit 우회 + 크레딧 차감 X. admin 권한 X · 사용자 데이터 접근 X.
# 형식: "key1:email1,key2:email2"  (콜론 = key/email 구분, 콤마 = 다중 키)
# 발급 방법: docs/INTERNAL_API_KEYS.md 참조
# 사용: 비서팀 호출 시 헤더에 `X-Internal-Key: sk_internal_xxx` 박음
INTERNAL_API_KEYS=sk_internal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:bot@reditowed.com
