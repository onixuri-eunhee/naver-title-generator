# ─────────────────────────────────────────────────────────────
# 뚝딱툴 환경변수 견본 — 코드에서 실제 사용하는 변수 전체 목록
# 실제 값은 .env.local(로컬) / Vercel·Railway 환경변수(배포)에 설정
# ─────────────────────────────────────────────────────────────

# ── 사이트 기본 ──
# Override site URL for OG/metadata in dev and preview deployments
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel이 자동 주입 (직접 설정 불필요): VERCEL_URL, NODE_ENV, PORT

# ── 데이터베이스 (Neon PostgreSQL) ──
POSTGRES_URL=postgres://user:password@host/dbname

# ── Redis (Upstash) — 세션·rate limit·작업 진행률 ──
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=AXxx...

# ── AI 모델 키 ──
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI — Whisper 전사 (Phase F 음성 업로드) + GPT Image 레거시 fallback
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
FAL_KEY=...

# ── Google Vertex AI / Cloud TTS ──
# 서비스 계정 인증 — 아래 셋 중 하나만 설정하면 됨 (우선순위 순)
GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY=        # base64 인코딩 JSON
GOOGLE_CLOUD_PROJECT=my-project-id
GOOGLE_VERTEX_PROJECT_ID=my-project-id
VERTEX_AI_LOCATION=us-central1
GOOGLE_VERTEX_LOCATION=us-central1
# 모델 ID 덮어쓰기 (선택)
GEMINI_VERTEX_MODEL=
GEMINI_VERTEX_FLASH_MODEL=
# 로컬 ADC 사용 시 자동 설정됨 (직접 설정 불필요): GOOGLE_APPLICATION_CREDENTIALS

# ── 네이버 API ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# ── 유튜브 ──
YOUTUBE_API_KEY=

# ── Threads (메타) ──
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── 결제 (토스페이먼츠) ──
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ── 파일 저장소 (Cloudflare R2) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── 비동기 작업 큐 (Upstash QStash) ──
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── 영상 렌더 서비스 (Railway) ──
RAILWAY_RENDER_URL=https://xxx.up.railway.app
RENDER_SECRET=                      # Vercel↔Railway 콜백 서명 비밀값
WEBHOOK_BASE_URL=                   # Railway→Vercel 콜백 기본 주소

# ── 관리자·내부 ──
ADMIN_EMAILS=admin@example.com,admin2@example.com
CRON_SECRET=                        # vercel.json 크론 인증
INTERNAL_API_SECRET=
# ── 내부 비서팀 API 키 (2026-04-30 도입) ──
# 무제한 호출 + rate limit 우회 + 크레딧 차감 X. admin 권한 X · 사용자 데이터 접근 X.
# 형식: "key1:email1,key2:email2"  (콜론 = key/email 구분, 콤마 = 다중 키)
# 발급 방법: docs/INTERNAL_API_KEYS.md 참조
# 사용: 비서팀 호출 시 헤더에 `X-Internal-Key: sk_internal_xxx` 추가
INTERNAL_API_KEYS=sk_internal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:bot@reditowed.com

# ── 기능 플래그 (선택) ──
SHORTFORM_ASYNC_WORKER=
SHORTFORM_BENCHMARK_DISABLED=
SHORTFORM_CORPUS_VERSION=
SHORTFORM_SLIM_PROMPT_ROLLOUT=
CARDNEWS_SLIM_PROMPT_ROLLOUT=

# ── 렌더 환경 (Docker가 설정, 직접 설정 불필요) ──
# PUPPETEER_EXECUTABLE_PATH, REMOTION_BROWSER_EXECUTABLE
