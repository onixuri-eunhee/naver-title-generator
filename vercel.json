{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/blog-image", "destination": "/api/blog-image" },
    { "source": "/api/threads", "destination": "/api/threads" },
    { "source": "/api/threads-publish", "destination": "/api/threads-publish" },
    { "source": "/api/threads-schedule", "destination": "/api/threads-schedule" },
    { "source": "/api/threads-callback", "destination": "/api/threads-callback" },
    { "source": "/api/threads-auth", "destination": "/api/threads-auth" },
    { "source": "/api/titles", "destination": "/api/titles" },
    { "source": "/api/hooks", "destination": "/api/hooks" },
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/admin", "destination": "/api/admin" },
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/card-news", "destination": "/api/card-news" },
    { "source": "/api/shortform-script", "destination": "/api/shortform-script" },
    { "source": "/api/shortform-stt", "destination": "/api/shortform-stt" },
    { "source": "/api/shortform-broll", "destination": "/api/shortform-broll" },
    { "source": "/api/shortform-tts", "destination": "/api/shortform-tts" },
    { "source": "/api/score-check", "destination": "/api/score-check" }
  ]
}
